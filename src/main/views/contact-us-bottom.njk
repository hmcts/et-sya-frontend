{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "components/web-chat.njk" import webChatModal %}

{% if "/" !== currentUrl and "/?lng=en" != currentUrl and "/?lng=cy" != currentUrl and hideContactUs === undefined %}

{% set contactHtml %}
  <p class="govuk-body">{{ contactUsForeword }}</p>

  <div class="govuk-body">
    {{ contactDuration }}<br>
    {{ mainTelephone }}<br>
    {{ welshTelephone }}<br>
    {{ scotlandTelephone }}<br>
    {% if i18n.language == "en" %}
      <table>
        <tr>
          <td>Webchat:</td>
          <td>{{ webChatModal() }}</td>
          <td>({{ scotlandOnly }})</td>
        </tr>
      </table>
    {% endif %}
  </div>

  <p class="govuk-body">
    <a href="https://www.gov.uk/call-charges" class="govuk-link" target="_blank">{{ contactCharges }}</a>
  </p>
{% endset %}

<div class="govuk-width-container">
  {{ govukDetails({
    summaryText: contactUsTitle,
    html: contactHtml
  }) }}
</div>

{% endif %}
