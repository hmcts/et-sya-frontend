{% extends "template.njk" %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}

{% block beforeContent %}
  {{ super() }}
  {% include "back-link.njk"%}
{% endblock %}

{% block content %}
  {% block errorSummary %}
   {% include "error-summary.njk" %}
  {% endblock %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">{{ legend }}</h1>

      <p class="govuk-body">
        {{ respondentName }}<br>
        {{ addressLine1 }}<br>
        {% if addressLine2 %}{{ addressLine2 }}<br>{% endif %}
        {{ addressTown }}<br>
        {% if addressCountry %}{{ addressCountry }}<br>{% endif %}
        {{ addressPostcode }}
      </p>

      <p class="govuk-hint">{{ hintText }}</p>

      {% block form %}
        {% include "form/form.njk"%}
      {% endblock %}
    </div>
  </div>
{% endblock %}
