{% macro timeoutModal() %}
  <div class="timeout-modal" id="timeout-modal" role="dialog" aria-modal="true" aria-hidden="true" tabindex="-1">
    <h2 class="govuk-heading-m" id="dialog-title" aria-hidden="true"> {{sessionTimeout.modal.title}} </h2>
    <p class="govuk-body" id="timer"> </p>
    <div id="sr-announcer" class="govuk-visually-hidden" aria-live="polite"></div>

    {{ govukButton({
      text: sessionTimeout.modal.extend,
      attributes: {
        id: 'extend-session'
      }
    }) }}

  </div>
  <div class="modal-overlay" id="modal-overlay" tabindex="-1" aria-hidden="true"></div>
{% endmacro %}
