{% macro timeoutModal() %}
  <div class="timeout-modal" id="timeout-modal" role="dialog" aria-live="polite" aria-labelledby="dialog-title" aria-describedby="at-timer" aria-hidden="true">
    <h2 class="govuk-heading-m" id="dialog-title"> {{sessionTimeout.modal.title}} </h2>
    <p class="govuk-visually-hidden" id="at-timer" role="status"> </p>
    <p class="govuk-body" id="timer" aria-hidden="true" aria-relevant="additions"> </p>

    {{ govukButton({
      text: sessionTimeout.modal.extend,
      attributes: {
        id: 'extend-session'
      }
    }) }}

  </div>
  <div class="modal-overlay" id="modal-overlay" tabindex="-1" aria-hidden="true"></div>
{% endmacro %}
