{% extends "template.njk" %}
{% from "govuk/components/details/macro.njk" import govukDetails %}

{% block beforeContent %}
  {{ super() }}
  {% include "back-link.njk"%}
{% endblock %}

{% block content %}

  {% block errorSummary %}
    {% include "error-summary.njk" %}
  {% endblock %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      <h1 class="govuk-heading-xl govuk-!-margin-bottom-4">{{ h1 }}</h1>

      <details class="govuk-details govuk-!-margin-bottom-2" data-module="govuk-details">
        <summary class="govuk-details__summary">
          <span class="govuk-details__summary-text">{{ detailsSummary }}</span>
        </summary>
        <div class="govuk-details__text">
          <p class="govuk-body">{{ detailsText.p1 }}</p>
          <p class="govuk-body">{{ detailsText.p2 }} <a href="{{ detailsText.govukLinkUrl }}" class="govuk-link" rel="noreferrer noopener" target="_blank">{{ detailsText.govukLinkText }}</a> {{ detailsText.p2Suffix }}</p>
        </div>
      </details>

      {% block form %}
        {% include "form/form.njk" %}
      {% endblock %}

    </div>
  </div>

{% endblock %}
