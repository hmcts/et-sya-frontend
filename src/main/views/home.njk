{% extends "template.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}
{% from "components/step-by-step-navigation/macro.njk" import stepByStepNavigation %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-xl govuk-!-margin-bottom-4 ">{{ pageTitle }}</h1>
      <p class="govuk-body">{{ serviceInfo }}</p>
      {{ govukInsetText({
        text: infoTxt
      }) }}
      {{ govukWarningText({
        html: warningTxt1,
        iconFallbackText: warningTxt
      }) }}
      <p class="govuk-body">{{ saveInfo }}</p>
      {{ govukWarningText({
        html: warningTxt2,
        iconFallbackText: warningTxt
      }) }}

      <div class="govuk-button-group">
        {{ govukButton({
          text: startANewClaim,
          href: redirectUrl
        }) }}

        {{ govukButton({
          text: returnToDraftOrSubmittedClaim,
          classes: "govuk-button--secondary",
          href: returnToExistingUrl
        }) }}
      </div>

      {{ stepByStepNavigation({
        steps: [
          {
            id: "check-you-can-make-a-claim",
            title: stepByStep.step1Title,
            body: stepByStep.step1Body,
            collapsible: false,
            links: [{ href: "https://www.acas.org.uk/early-conciliation", text: stepByStep.step1Link, external: true }]
          },
          {
            id: "prepare-your-personal-details",
            title: stepByStep.step2Title,
            collapsible: false,
            body: stepByStep.step2Body
          },
          {
            id: "provide-your-employment-information",
            title: stepByStep.step3Title,
            collapsible: false,
            body: stepByStep.step3Body
          },
          {
            id: "describe-your-claim",
            title: stepByStep.step4Title,
            collapsible: false,
            body: stepByStep.step4Body
          },
          {
            id: "review-and-submit",
            title: stepByStep.step5Title,
            body: stepByStep.step5Body,
            collapsible: false,
            links: [{ href: redirectUrl, text: stepByStep.step5Link }]
          }
        ]
      }) }}

      <h2 class="govuk-heading-m">{{ contactUsHelpTitle }}</h2>
      <div class="govuk-body">
          {{ contactUsForeword }}
          <br><br>
          {{ contactDuration }}<br/>
          {{ mainTelephone }}<br/>
          {{ welshTelephone }}<br/>
          {{ scotlandTelephone }}<br/>
          {% if i18n.language == "en" %}
            <table><tr><td>Webchat:</td><td>{{ webChatModal() }}</td><td>({{ scotlandOnly }})</td></tr></table><br/>
          {% else %}
            <br/><br/>
          {% endif %}
          <p class="govuk-body">
          <a href="https://www.gov.uk/call-charges" class="govuk-link" target="_blank">
            {{ contactCharges }}
          </a>
          </p>
        </div>
      </div>
    </div>
{% endblock %}
