{% extends "template.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% block beforeContent %}
  {{ super() }}
  {% include "back-link.njk"%}
{% endblock %}

{% block content %}
  {% block errorSummary %}
    {% include "error-summary.njk" %}
  {% endblock %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l govuk-!-margin-bottom-4">{{ title }}</h1>

      {% for respondent in respondents %}
        {{ govukSummaryList({
          card: {
            title: {
              text: subTitle + loop.index
            }
          },
          rows: getClaimantRespondentDetailsSection(respondent, translations)
        }) }}
      {% endfor %}

      <p class="govuk-body">
        <a href="{{ PageUrls.CLAIMANT_RESPONDENT_NAME + languageParam }}" class="govuk-link">
          {{ addAnotherRespondent }}
        </a>
      </p>

      {% block form %}
        {% include "form/form.njk"%}
      {% endblock %}
    </div>
  </div>
{% endblock %}
