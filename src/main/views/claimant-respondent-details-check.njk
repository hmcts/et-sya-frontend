{% extends "template.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% block beforeContent %}
  {{ super() }}
  {% include "back-link.njk"%}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l govuk-!-margin-bottom-4">{{ title }}</h1>

      {% for respondent in respondents %}
        {{ govukSummaryList({
          card: {
            title: {
              text: subTitle + loop.index
            }
          },
          rows: getClaimantRespondentDetailsSection(respondent, translations)
        }) }}
      {% endfor %}

      {{ govukButton({
        text: addAnotherRespondent,
        href: PageUrls.CLAIMANT_RESPONDENT_ADD_REDIRECT + languageParam,
        classes: "govuk-button--secondary"
      }) }}

      <form method="post" action="" novalidate="true">
        <input type="hidden" name="_csrf" value={{ csrfToken }}>
        {{ govukButton({
          text: saveAndContinue,
          preventDoubleClick: true
        }) }}
      </form>
    </div>
  </div>
{% endblock %}
