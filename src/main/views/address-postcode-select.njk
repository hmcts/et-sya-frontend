{% from "govuk/components/select/macro.njk" import govukSelect %}
{% extends "template.njk" %}

{% block beforeContent %}
  {{ super() }}
  {% include "back-link.njk"%}
{% endblock %}

{% block content %}
  {% block errorSummary %}
    {% include "error-summary.njk" %}
  {% endblock %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      {% block form %}
        {% include "form/form.njk"%}
      {% endblock %}
      {% if form.fields.additionalClaimantAddressTypes and userCase.additionalClaimantAddresses %}
        <div id="additional-claimant-address-data" class="hidden" aria-hidden="true">
          {% for address in userCase.additionalClaimantAddresses %}
            <div
              class="js-additional-claimant-address-data"
              data-line1="{{ address.street1 }}"
              data-line2="{{ address.street2 }}"
              data-town="{{ address.town }}"
              data-country="{{ address.country }}"
              data-postcode="{{ address.postcode }}"
            ></div>
          {% endfor %}
        </div>
      {% endif %}
      {% if not form.fields.additionalClaimantAddressTypes %}
       <p class="govuk-body">
         <a href="{{ link }}" id="cannotFindAddress" class="govuk-link" target="_self">{{ cannotFindAddress }}</a>
       </p>
      {% endif %}
    </div>
  </div>
{% endblock %}
