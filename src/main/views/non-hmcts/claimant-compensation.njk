{% extends "template.njk" %}

{% block beforeContent %}
  {{ super() }}
  {% include "back-link.njk"%}
{% endblock %}

{% block content %}
  {% block errorSummary %}
    {% include "error-summary.njk" %}
  {% endblock %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-xl govuk-!-margin-bottom-4">{{ h1 }}</h1>

      <details class="govuk-details govuk-!-margin-bottom-2" data-module="govuk-details">
        <summary class="govuk-details__summary">
          <span class="govuk-details__summary-text">{{ detailsSummaryComp }}</span>
        </summary>
        <div class="govuk-details__text">
          {{ detailsTextComp.p1 }}
          <ul>
            <li>{{ detailsTextComp.li1 }}</li>
            <li>{{ detailsTextComp.li2 }}</li>
          </ul>
          <p class="govuk-body">{{ detailsTextComp.p2 }}</p>
          <p class="govuk-body">{{ detailsTextComp.p3 }} <a href="{{ detailsTextComp.acasLinkUrl }}" class="govuk-link" rel="noreferrer noopener" target="_blank">{{ detailsTextComp.acasLinkText }}</a></p>
          <p class="govuk-body">{{ detailsTextComp.p4 }} <a href="{{ detailsTextComp.acasLinkUrl }}" class="govuk-link" rel="noreferrer noopener" target="_blank">{{ detailsTextComp.acasLinkText }}</a></p>
          {{ detailsTextComp.p5 }}
        </div>
      </details>

      {% block form %}
        {% include "form/form.njk" %}
      {% endblock %}
    </div>
  </div>
{% endblock %}
