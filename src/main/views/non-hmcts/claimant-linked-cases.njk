{% extends "template.njk" %}

{% block beforeContent %}
  {{ super() }}
  {% include "back-link.njk"%}
{% endblock %}

{% block content %}

  {% block errorSummary %}
   {% include "error-summary.njk" %}
  {% endblock %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      <h1 class="govuk-heading-xl govuk-!-margin-bottom-4">{{ h1 }}</h1>
      <p class="govuk-body">{{ p1 }}</p>
      <p class="govuk-body">{{ p2 }}</p>
      <ul class="govuk-list govuk-list--bullet">
        <li>{{ li1 }}</li>
        <li>{{ li2 }}</li>
      </ul>
      <p class="govuk-body">{{ p3 }}</p>

      {% block form %}
        <form class="form" id="main-form" method="post" action="" novalidate="true">
          <input type="hidden" name="_csrf" value={{ csrfToken }}>
          {% include "form/fields.njk" %}
          <p class="govuk-body">
            <a href="{{ PageUrls.CLAIMANT_LINKED_CASES }}?redirect=clearSelection&{{ languageParam }}" class="govuk-link">{{ clearSelection }}</a>
          </p>
          {% include "form/saveButtons.njk" %}
        </form>
      {% endblock %}
    </div>
  </div>
{% endblock %}